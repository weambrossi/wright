# Anthropic (AI features)
ANTHROPIC_API_KEY=your_key_here

# Supabase (document storage) — from your project's Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Access gate (single shared password)
# APP_PASSWORD is what you/your dad type to log in.
# SESSION_SECRET is a long random string (e.g. `openssl rand -hex 32`); it is
# the cookie value, so keep it secret and never reuse it as the password.
APP_PASSWORD=choose_a_password
SESSION_SECRET=replace_with_a_long_random_string
